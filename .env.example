# Paperless-ngx (required). URL must include the /api suffix, e.g. http://paperless:8000/api
PAPERLESS_API_URL=http://localhost:8000/api
PAPERLESS_API_TOKEN=
PAPERLESS_USERNAME=

# Feature toggles
# ENABLE_TAGGING: automatic scan → AI → Paperless updates (default true)
ENABLE_TAGGING=true
# RAG_SERVICE_ENABLED: Python RAG service + /api/rag routes (default true)
RAG_SERVICE_ENABLED=true
RAG_SERVICE_URL=http://localhost:8000

# AI (required only when ENABLE_TAGGING=true)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=
AZURE_ENDPOINT=
AZURE_API_KEY=
AZURE_DEPLOYMENT_NAME=
AZURE_API_VERSION=2023-05-15

SCAN_INTERVAL=*/30 * * * *

# Legacy app auth (JWT + x-api-key); remove when auth is reworked per plan PR 03.
API_KEY=
JWT_SECRET=

# Optional: legacy file at data/.env is still loaded when present (after process env).
